{
  "_scripts": ["log-cost.sh"],
  "_description": "Log token usage per turn to ~/.claude/cost-log.csv",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash __HOOKS_DIR__/cost-log/log-cost.sh"
          }
        ]
      }
    ]
  }
}
