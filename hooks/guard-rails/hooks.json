{
  "_scripts": ["protect-files.sh"],
  "_description": "Protect sensitive files (.env, keys, credentials)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HOOKS_DIR__/guard-rails/protect-files.sh"
          }
        ]
      }
    ]
  }
}
